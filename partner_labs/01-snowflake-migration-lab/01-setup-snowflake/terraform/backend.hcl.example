# Optional: use S3 backend for shared state across team members.
# Steps:
#   1. Copy this file to backend.hcl (gitignored).
#   2. Fill in the values for your environment.
#   3. Run: terraform init -backend-config=backend.hcl
#   4. In main.tf, replace the backend "local" block with backend "s3" {}.

bucket         = "clickhouse-lab-tf-state"
key            = "snowflake/migration-lab/terraform.tfstate"
region         = "us-east-1"
encrypt        = true
dynamodb_table = "clickhouse-lab-tf-lock"
