            AGG_SF[["AGG_HOURLY_ZONE_TRIPS<br/>~2 M rows"]]
        end
    end

    subgraph MIGRATE ["  Python Migration (one-time)  "]
        direction TB
        PY_MIGRATE(["scripts/02_migrate_trips.py<br/>100K-row batches<br/>~40-50 min"])
    end

    PRD        -->|"INSERT ~60 rows/min"| TRIPS_RAW
    TRIPS_RAW  -->|"dbt source"| DBT_SF
    DBT_SF     -->|"MERGE incremental"| FACT_SF
    DBT_SF     -->|"MERGE aggregate"| AGG_SF
    TRIPS_RAW  -->|"one-time full migration"| PY_MIGRATE

    classDef source   fill:#48C78E,color:#fff,stroke:#2ea06a,stroke-width:2px
    classDef sfTable  fill:#29B5E8,color:#fff,stroke:#1a8bb8,stroke-width:2px
