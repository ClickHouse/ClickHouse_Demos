            TRIPS_RAW[["TRIPS_RAW<br/>50 M rows<br/>VARIANT: TRIP_METADATA"]]
        end

        DBT_SF(["dbt-snowflake<br/>staging → analytics<br/>MERGE incremental"])

        subgraph ANALYTICS_SCHEMA ["ANALYTICS Schema"]
