%%{init: {"theme": "base", "themeVariables": {"fontSize": "14px"}}}%%
flowchart TB
    PRD["Trip Producer<br/>~60 trips / min · Docker<br/>pre-cutover"]

    subgraph SF ["  Snowflake — NYC_TAXI_DB (Part 1 source)  "]
