#!/usr/bin/env bash
# Environment variables for the Observability Migration Lab
# Copy this file to env.sh and fill in your values:
#   cp common/env.sh.example common/env.sh
# Then source it before running any script:
#   source common/env.sh

# ──────────────────────────────────────────────
# Source Environment (Part 1)
# ──────────────────────────────────────────────

# Elasticsearch — use "localhost" for local Docker, or your EC2 public IP
export ES_HOST="localhost"
export ES_PORT="9200"
export ES_URL="http://${ES_HOST}:${ES_PORT}"

# Kibana
export KIBANA_HOST="localhost"
export KIBANA_PORT="5601"
export KIBANA_URL="http://${KIBANA_HOST}:${KIBANA_PORT}"

# APM Server
export APM_HOST="localhost"
export APM_PORT="8200"

# ──────────────────────────────────────────────
# Target Environment (Part 3)
# ──────────────────────────────────────────────

# ClickHouse Cloud — native TLS connection (port 9440)
# Find in: Cloud console → Your service → Connect → Native protocol
export CH_HOST="<your-service>.clickhouse.cloud"
export CH_PORT="9440"
export CH_USER="default"
export CH_PASSWORD="<your-password>"

# ClickHouse Cloud API — used for ClickStack dashboard import (Step 5)
# CH_ORG_ID:            Cloud console → org menu → Organisation ID
# CH_SERVICE_ID:        Cloud console → Your service → Settings → Service ID
# CH_API_KEY_ID/SECRET: Cloud console → API Keys → Create key
export CH_ORG_ID="<your-org-id>"
export CH_SERVICE_ID="<your-service-id>"
export CH_API_KEY_ID="<your-api-key-id>"
export CH_API_KEY_SECRET="<your-api-key-secret>"
